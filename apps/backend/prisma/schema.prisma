// PixJob — Prisma Schema
// Sprint 1 (Security Review): Authentication & Identity

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  CLIENT
  DESIGNER
  MODERATOR
  SUPPORT
  FINANCE
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  PENDING    // Registered but email not yet verified
  ACTIVE     // Fully verified and able to use the platform
  SUSPENDED  // Temporarily restricted by a moderator/admin
  BANNED     // Permanently restricted
  DELETED    // Soft-deleted; treated as non-existent in auth flows
}

// ─── Users ────────────────────────────────────────────────────────────────────

model User {
  id        String     @id @default(uuid()) @db.Uuid
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  email     String     @unique @db.VarChar(320)
  username  String     @unique @db.VarChar(50)
  password  String     // argon2id hash — NEVER plain text
  firstName String?    @map("first_name") @db.VarChar(100)
  lastName  String?    @map("last_name") @db.VarChar(100)
  status    UserStatus @default(PENDING)

  // Relations
  userRoles          UserRoleAssignment[]
  sessions           Session[]
  emailVerifications EmailVerification[]
  auditLogs          AuditLog[]

  @@map("users")
}

// ─── Roles & Permissions (RBAC) ───────────────────────────────────────────────

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  name        UserRole @unique
  description String?  @db.VarChar(255)

  userRoles   UserRoleAssignment[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  // Permission key format: "<resource>.<action>", e.g. "users.read", "roles.write"
  action      String   @db.VarChar(100)
  subject     String   @db.VarChar(100)
  description String?  @db.VarChar(255)

  roles RolePermission[]

  @@unique([action, subject])
  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(uuid()) @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid

  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserRoleAssignment {
  id        String   @id @default(uuid()) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  userId    String   @map("user_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

// ─── Sessions ─────────────────────────────────────────────────────────────────

model Session {
  id           String    @id @default(uuid()) @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  userId       String    @map("user_id") @db.Uuid
  // SECURITY: Only the argon2id hash of the refresh token is stored here.
  // The raw token is issued to the client and never persisted.
  // A database compromise will NOT expose any valid refresh tokens.
  refreshToken String    @unique @map("refresh_token") @db.VarChar(512)
  userAgent    String?   @map("user_agent") @db.VarChar(512)
  ipAddress    String?   @map("ip_address") @db.VarChar(45)
  expiresAt    DateTime  @map("expires_at")
  revokedAt    DateTime? @map("revoked_at")

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, revokedAt]) // speeds up findActiveSessionsForUser
  @@map("sessions")
}

// ─── Email Verifications ──────────────────────────────────────────────────────

model EmailVerification {
  id        String    @id @default(uuid()) @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at")

  userId    String    @map("user_id") @db.Uuid
  // SECURITY: Only the argon2id hash of the OTP is stored.
  token     String    @unique @db.VarChar(512)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verifications")
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  userId    String?  @map("user_id") @db.Uuid
  // Structured action name, e.g. "auth.register", "auth.login.failed"
  action    String   @db.VarChar(100)
  // entityType: resource type acted upon, e.g. "User", "Session"
  subject   String?  @map("entity_type") @db.VarChar(100)
  // entityId: UUID or identifier of the specific resource
  subjectId String?  @map("entity_id") @db.VarChar(36)
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  userAgent String?  @map("user_agent") @db.VarChar(512)
  // Arbitrary structured metadata (JSON) — e.g. failure reason, changed fields
  metadata  Json?

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt]) // enables time-range queries for compliance reports
  @@map("audit_logs")
}
