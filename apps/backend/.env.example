# ─── Backend .env.example ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# Prisma / PostgreSQL
DATABASE_URL=postgresql://pixjob:pixjob_secret@localhost:5432/pixjob_dev

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret
REDIS_DB=0

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_generate_a_real_64byte_hex_secret
JWT_REFRESH_SECRET=CHANGE_ME_generate_a_different_64byte_hex_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

FRONTEND_URL=http://localhost:3000

# Seed
SUPER_ADMIN_EMAIL=admin@pixjob.com
SUPER_ADMIN_PASSWORD=SuperAdmin@123
