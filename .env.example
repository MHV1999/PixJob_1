# ─── Root-level .env.example ──────────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=pixjob
POSTGRES_PASSWORD=pixjob_secret
POSTGRES_DB=pixjob_dev
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret
REDIS_DB=0

# ── Backend ───────────────────────────────────────────────────────────────────
BACKEND_PORT=4000
NODE_ENV=development

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_generate_a_real_64byte_hex_secret
JWT_REFRESH_SECRET=CHANGE_ME_generate_a_different_64byte_hex_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

FRONTEND_URL=http://localhost:3000

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
